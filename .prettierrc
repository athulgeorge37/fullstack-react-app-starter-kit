{
	"printWidth": 80,
	"tabWidth": 4,
	"useTabs": true,
	"singleAttributePerLine": true,
	"semi": true,
	"singleQuote": false,
	"jsxSingleQuote": false,
	"trailingComma": "all",
	"bracketSpacing": true,
	"objectWrap": "preserve",
	"bracketSameLine": false,
	"arrowParens": "always",

	"plugins": ["@ianvs/prettier-plugin-sort-imports"],
	"importOrder": [
		"",
		"<TYPES>^(node:)",
		"",
		"<TYPES>",
		"",
		"<TYPES>^[.]",
		"",
		"^react$",
		"",
		"<BUILTIN_MODULES>",
		"",
		"<THIRD_PARTY_MODULES>",
		"",
		"^[.]"
	],
	"importOrderTypeScriptVersion": "5.9.2",
	"importOrderCaseSensitive": true
}
